#!/usr/bin/env bash
#
# pre-push: block pushes that introduce secrets into this PUBLIC repo.
#
# Activated via `core.hooksPath hooks` (see hooks/install.sh). Scans only the
# commits actually being pushed — fast, since it never touches the working tree
# or untracked blobs. Prefers gitleaks; falls back to a regex scan if absent.
#
# Bypass a false positive with:  git push --no-verify
# Tune detection rules in:       .gitleaks.toml
#
set -uo pipefail

ZERO='0000000000000000000000000000000000000000'
RED=$'\033[0;31m'; GRN=$'\033[0;32m'; YLW=$'\033[1;33m'; NC=$'\033[0m'

ranges=()
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue            # branch deletion: nothing to scan
  if [ "$remote_sha" != "$ZERO" ] && git rev-parse -q --verify "$remote_sha^{commit}" >/dev/null 2>&1; then
    ranges+=("$remote_sha..$local_sha")             # update: scan only the new commits
  else
    # New branch, OR remote tip not present locally (remote moved ahead / force-pushed
    # elsewhere). Fall back to scanning every local commit not on any remote-tracking
    # branch — never trust an unresolvable remote sha.
    ranges+=("$local_sha --not --remotes")
  fi
done

[ ${#ranges[@]} -eq 0 ] && exit 0                    # delete-only push

echo "${YLW}pre-push: scanning outgoing commits for secrets...${NC}"
fail=0

if command -v gitleaks >/dev/null 2>&1; then
  for range in "${ranges[@]}"; do
    # Fail CLOSED: if the range can't be resolved, block rather than skip.
    if ! git rev-list $range >/dev/null 2>&1; then
      echo "${RED}pre-push: cannot resolve commit range '$range' - blocking. Try: git fetch${NC}"
      fail=1; continue
    fi
    gitleaks git . --no-banner --redact --log-opts="$range" || fail=1
  done
else
  echo "${YLW}gitleaks not found - using regex fallback (brew install gitleaks for full coverage)${NC}"
  pat='(sk-[A-Za-z0-9]{20,}|ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{50,}|gho_[A-Za-z0-9]{36}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|xox[baprs]-[0-9A-Za-z-]{10,}|glpat-[0-9A-Za-z_-]{20}|-----BEGIN [A-Z ]*PRIVATE KEY-----|(api[_-]?key|secret|token|password)["'"'"' ]*[:=]["'"'"' ]*[A-Za-z0-9/+_-]{16,})'
  for range in "${ranges[@]}"; do
    hits=$(git log -p --no-color $range -- 2>/dev/null | grep -E '^\+' | grep -inE "$pat" | grep -vEi 'kubectl get secrets|get_secret|getSecret' | head -20)
    if [ -n "$hits" ]; then
      echo "${RED}Potential secret(s) in $range:${NC}"
      echo "$hits"
      fail=1
    fi
  done
fi

if [ "$fail" -ne 0 ]; then
  echo
  echo "${RED}Push blocked: potential secrets detected.${NC}"
  echo "  - Remove the secret and amend/rewrite the offending commit(s), then re-push."
  echo "  - False positive? Bypass once with: ${YLW}git push --no-verify${NC}"
  echo "  - Allowlist a known-safe match in .gitleaks.toml"
  exit 1
fi

echo "${GRN}pre-push: no secrets detected - push allowed.${NC}"
exit 0
